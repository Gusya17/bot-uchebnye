# Скопируй этот файл в .env и заполни реальными значениями
# Файл .env НЕ должен попасть в Git — он уже добавлен в .gitignore

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=токен_telegram_бота

# Telegram ID владельца (получить у @userinfobot)
OWNER_TELEGRAM_ID=твой_telegram_id

# Email для отправки уведомлений владельцу
OWNER_EMAIL=inga17@mail.ru

# Почта, с которой бот будет отправлять письма (например, на mail.ru)
EMAIL_LOGIN=почта_бота@mail.ru
EMAIL_PASSWORD=пароль_от_почты

# Ключ OpenAI для расшифровки голосовых сообщений (Whisper)
OPENAI_API_KEY=ключ_openai
